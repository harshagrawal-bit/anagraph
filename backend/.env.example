# ============================================================
# HedgeOS — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# PRIMARY AI: Anthropic Claude Opus (required for production)
# Get key at: https://console.anthropic.com — add $20 credit
ANTHROPIC_API_KEY=your_anthropic_key_here

# FALLBACK AI: Groq (free tier — for dev/testing without Anthropic key)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
MODEL=llama-3.3-70b-versatile
MAX_TOKENS=8096

# Reddit API — for sentiment analysis (Phase 2)
# Create a script app at: https://reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=hedgeos_research_v1

# Flask (Phase 4 — multi-agent crew runner)
FLASK_ENV=development
FLASK_PORT=5000

# FastAPI
FASTAPI_PORT=8000

# SEC EDGAR user-agent (required by SEC — use your real contact info)
SEC_USER_AGENT=HedgeOS research@youremail.com
